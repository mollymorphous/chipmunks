#
# EditorConfig is awesome: https://editorconfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file and UTF-8 everywhere
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8

# Python (matching ruff/Black defaults)
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# TOML (matching Tombi)
[*.toml]
indent_style = space
indent_size = 2